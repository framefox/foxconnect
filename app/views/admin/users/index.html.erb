<% content_for :title, "Users - Framefox Connect Admin" %>

<div class="space-y-6">
  <!-- Page Header -->
  <div class="flex items-center justify-between">
    <div class="space-y-2">
      <h1 class="scroll-m-20 text-3xl font-semibold tracking-tight text-slate-900">
        Users
      </h1>
      <p class="text-lg text-slate-600">
        Manage user accounts and their store connections.
      </p>
    </div>
    
    <%= link_to new_admin_user_path, class: "bg-slate-900 text-slate-50 hover:bg-slate-800 px-4 py-2 rounded-md text-sm font-medium transition-colors" do %>
      Add New User
    <% end %>
  </div>

  <!-- Users Table -->
  <div class="bg-white border border-slate-200 rounded-lg overflow-hidden">
    <% if @users.any? %>
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Name</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Email</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Organization</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Country</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Stores</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Joined</th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-slate-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200">
          <% @users.each do |user| %>
            <tr class="hover:bg-slate-50 transition-colors">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center space-x-2">
                  <%= link_to user.full_name, admin_user_path(user), class: "text-sm font-medium text-slate-900 hover:text-blue-600 transition-colors" %>
                  <% if user.admin? %>
                    <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800">Admin</span>
                  <% end %>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600"><%= user.email %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm">
                <% if user.organization.present? %>
                  <%= link_to user.organization.name, admin_organization_path(user.organization), class: "text-blue-600 hover:underline" %>
                <% else %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-800">No Org</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600"><%= user.country_name if user.country.present? %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600"><%= user.stores.count %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500"><%= user.created_at.strftime("%d %b %Y") %></td>
              <td class="px-6 py-4 whitespace-nowrap text-right">
                <div class="flex items-center justify-end space-x-2">
                  <%= link_to admin_user_path(user), class: "bg-slate-100 text-slate-700 hover:bg-slate-200 px-3 py-1.5 rounded-md text-sm font-medium transition-colors" do %>
                    View
                  <% end %>
                  <%= link_to edit_admin_user_path(user), class: "bg-slate-100 text-slate-700 hover:bg-slate-200 px-3 py-1.5 rounded-md text-sm font-medium transition-colors" do %>
                    Edit
                  <% end %>
                  <%= button_to impersonate_admin_user_path(user),
                      method: :post,
                      class: "bg-yellow-100 text-yellow-800 hover:bg-yellow-200 px-3 py-1.5 rounded-md text-sm font-medium transition-colors" do %>
                    Impersonate
                  <% end %>

                  <div class="relative" data-dropdown>
                    <button type="button" data-dropdown-trigger class="inline-flex items-center p-1.5 rounded-md text-slate-400 hover:text-slate-600 hover:bg-slate-100 transition-colors">
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"></path>
                      </svg>
                    </button>
                    <div data-dropdown-menu class="hidden absolute right-0 z-10 mt-2 w-48 rounded-md shadow-lg bg-white ring-1 ring-black ring-opacity-5">
                      <div class="py-1" role="none">
                        <%= button_to admin_user_path(user),
                            method: :delete,
                            form: { onsubmit: "return confirm('Are you sure you want to delete this user? This will also remove their stores and Shopify accounts.')", class: "w-full" },
                            class: "group flex items-center w-full text-left px-4 py-2 text-sm text-red-700 hover:bg-red-50",
                            role: "menuitem" do %>
                          <svg class="mr-3 w-4 h-4 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                          Delete
                        <% end %>
                      </div>
                    </div>
                  </div>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <%= render "admin/shared/pagination", pagy: @pagy, url_helper: ->(p) { admin_users_path(p) } %>
    <% else %>
      <div class="text-center py-12">
        <div class="w-16 h-16 bg-slate-100 rounded-lg flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-slate-900 mb-2">No users yet</h3>
        <p class="text-sm text-slate-600 mb-4">Add your first user to get started.</p>
        <%= link_to new_admin_user_path, class: "bg-slate-900 text-slate-50 hover:bg-slate-800 px-4 py-2 rounded-md text-sm font-medium transition-colors inline-flex items-center" do %>
          Add First User
        <% end %>
      </div>
    <% end %>
  </div>
</div>
